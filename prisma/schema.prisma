generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP
}

enum AgentType {
  TECHNICAL_ANALYST
  NEWS_ANALYST
  FUNDAMENTALS_ANALYST
  RISK_ANALYST
  MACRO_ANALYST
  SENTIMENT_ANALYST
  QUANT_ANALYST
  CRYPTO_SPECIALIST
  BULL_RESEARCHER
  BEAR_RESEARCHER
  TRADER_AGENT
  AGGRESSIVE_RISK
  NEUTRAL_RISK
  CONSERVATIVE_RISK
  PORTFOLIO_MANAGER
  TEAM_LEAD
}

enum AgentStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum OrderStatus {
  PENDING
  FILLED
  PARTIALLY_FILLED
  CANCELED
  REJECTED
  EXPIRED
}

enum Recommendation {
  BUY
  HOLD
  AVOID
}

model DemoAccount {
  id        String      @id @default(cuid())
  ownerKey  String      @unique @default("demo")
  cash      Float       @default(100000)
  realizedPnl Float     @default(0)
  positions Position[]
  trades    Trade[]
  orders    Order[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Position {
  id          String      @id @default(cuid())
  accountId   String
  account     DemoAccount @relation(fields: [accountId], references: [id])
  ticker      String
  quantity    Int
  averageCost Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([accountId, ticker])
}

model Trade {
  id        String      @id @default(cuid())
  accountId String
  account   DemoAccount @relation(fields: [accountId], references: [id])
  orderId   String?
  order     Order?      @relation(fields: [orderId], references: [id])
  ticker    String
  side      TradeSide
  quantity  Int
  price     Float
  orderType OrderType   @default(MARKET)
  requestedPrice Float?
  createdAt DateTime    @default(now())

  @@index([orderId])
}

model Order {
  id        String      @id @default(cuid())
  accountId String
  account   DemoAccount @relation(fields: [accountId], references: [id])
  ticker    String
  side      TradeSide
  quantity  Int
  filledQuantity Int     @default(0)
  status    OrderStatus @default(PENDING)
  orderType OrderType   @default(MARKET)
  limitPrice Float?
  stopPrice  Float?
  averageFillPrice Float?
  lastCheckedPrice Float?
  rejectionReason String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  filledAt  DateTime?
  canceledAt DateTime?
  expiresAt DateTime?
  trades    Trade[]

  @@index([accountId, status, createdAt])
  @@index([ticker, status])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  ownerKey  String   @default("demo")
  ticker    String
  createdAt DateTime @default(now())

  @@unique([ownerKey, ticker])
}

model AnalysisRun {
  id              String         @id @default(cuid())
  ticker          String
  idempotencyKey  String?
  status          AgentStatus    @default(PENDING)
  errorReason     String?
  finalSummary    String?
  finalRec        Recommendation?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  recommendations AgentResult[]

  @@index([ticker, createdAt])
  @@index([idempotencyKey])
}

model AgentResult {
  id             String         @id @default(cuid())
  analysisRunId  String
  analysisRun    AnalysisRun    @relation(fields: [analysisRunId], references: [id])
  agentType      AgentType
  status         AgentStatus    @default(PENDING)
  errorReason    String?
  summary        String?
  confidence     Float?
  recommendation Recommendation?
  reasons        Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([analysisRunId, agentType])
}
